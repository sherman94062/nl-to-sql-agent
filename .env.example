# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# ---------------------------------------------------------------------------
# Database — pick ONE of the two options below
# ---------------------------------------------------------------------------

# Option 1: SQLite (default, no setup needed)
# Defaults to db/ecommerce.db. Override the path if you want a different file:
# DB_PATH=db/ecommerce.db

# Option 2: PostgreSQL
# Set DATABASE_URL and the agent will use PostgreSQL instead of SQLite.
# The schema is introspected automatically, so it works with any database.
#
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
#
# Or use individual vars if you prefer (not used when DATABASE_URL is set):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=myuser
# PGPASSWORD=mypassword
# PGDATABASE=mydb
